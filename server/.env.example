# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/vpnsite
DATABASE_SSL=false

# JWT (сгенерируйте длинную случайную строку)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# SMTP — для отправки кодов на почту
# Примеры: smtp.yandex.ru, smtp.gmail.com, smtp.mail.ru
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
# или SMTP_PASSWORD=your-app-password
SMTP_FROM="Кофемания VPN <your@email.com>"

# Опционально
APP_NAME=Кофемания VPN
PORT=3001
FRONTEND_URL=http://localhost:5173

# Напоминания о скором окончании подписки (за 3 дня, за 1 день, в день окончания)
# SUBSCRIPTION_REMINDERS_ENABLED=false
# SUBSCRIPTION_REMINDERS_INTERVAL_HOURS=1

# Telegram Login Widget (BotFather → Bot Settings → Domain)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_name

# Remnawave API (создание VPN ключей и подписки)
REMNAWAVE_API_URL=https://your-remnawave-panel.com/api
REMNAWAVE_API_KEY=your-api-key-here

# YooKassa (shopId и секретный ключ из личного кабинета ЮKassa)
YOOKASSA_ACCOUNT_ID=
YOOKASSA_SECRET_KEY=
# Альтернативные имена (поддерживаются): YOOKASSA_SHOP_ID, YOOKASSA_API_KEY
# Чек 54-ФЗ — только если в кабинете включена онлайн-касса (иначе false)
YOOKASSA_USE_RECEIPT=false
YOOKASSA_TIMEOUT=12
YOOKASSA_MAX_ATTEMPTS=1
YOOKASSA_PYTHON_TIMEOUT_MS=18000
REMNAWAVE_PYTHON_TIMEOUT_MS=90000
# URL возврата после оплаты (должен вести на /my-keys?payment=return)
# YOOKASSA_RETURN_URL=http://localhost:5173/my-keys?payment=return
# Доп. origin для return_url с фронта (ngrok и т.д.), через запятую
# ALLOWED_RETURN_ORIGINS=https://your-ngrok.ngrok-free.dev
