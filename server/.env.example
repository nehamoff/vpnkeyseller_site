# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/vpnsite
DATABASE_SSL=false

# JWT (сгенерируйте длинную случайную строку)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# SMTP — для отправки кодов на почту
# Примеры: smtp.yandex.ru, smtp.gmail.com, smtp.mail.ru
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
# или SMTP_PASSWORD=your-app-password
SMTP_FROM="Кофемания VPN <your@email.com>"

# Опционально
APP_NAME=Кофемания VPN
PORT=3001
FRONTEND_URL=http://localhost:5173
