# ==========================================
# CaféMania VPN - Production Environment
# ==========================================

# ========== NODE.JS ==========
NODE_ENV=production
PORT=3001

# ========== DATABASE ==========
DATABASE_URL=postgresql://deploy:your-secure-password@localhost:5432/cafemaniavpn
DB_PASSWORD=your-secure-password

# ========== JWT ==========
JWT_SECRET=your-very-long-random-string-here-change-this-immediately

# ========== FRONTEND ==========
FRONTEND_URL=https://coffeemaniavpn.ru

# ========== REMNAWAVE VPN INTEGRATION ==========
# Получить от администратора Remnawave панели
REMNAWAVE_BASE_URL=https://panel.coffemaniavpn.online/
REMNAWAVE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
REMNAWAVE_ADMIN_LOGIN=admin
REMNAWAVE_ADMIN_PASSWORD=your-admin-password

# ========== TEST MODE (false в production) ==========
TEST_MODE=false

# ========== EMAIL (SMTP) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@coffeemaniavpn.ru

# ========== TELEGRAM ==========
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ========== PAYMENT GATEWAY (YooKassa/Stripe) ==========
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_API_KEY=your-api-key
STRIPE_SECRET_KEY=sk_live_...

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FILE=/var/log/cafemaniavpn/app.log

# ========== SECURITY ==========
CORS_ORIGIN=https://coffeemaniavpn.ru
SESSION_SECRET=your-session-secret-key

# ========== OPTIONAL: RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
